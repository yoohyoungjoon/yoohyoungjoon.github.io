---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Comments from "../components/Comments.astro";

// Shared by Food, Architecture, and Sports. `kind` toggles which extra meta
// fields show.
interface Props {
  kind: "food" | "architecture" | "sports";
  data: {
    title: string;
    date: Date;
    tags?: string[];
    location?: string;
    rating?: number;
    year_built?: number | string;
    architect?: string;
    competition?: string;
    result?: string;
    cover_image?: import("astro").ImageMetadata;
    cover_alt?: string;
  };
}
const { kind, data } = Astro.props;
const BACK = {
  food: { href: "/food", label: "Food" },
  architecture: { href: "/architecture", label: "Architecture" },
  sports: { href: "/sports", label: "Sports" },
} as const;
const backHref = BACK[kind].href;
const backLabel = BACK[kind].label;

// Render a rating like 4.5 as ★★★★½ (kept simple and quiet).
function stars(n: number) {
  const full = Math.floor(n);
  const half = n - full >= 0.5;
  return "★".repeat(full) + (half ? "½" : "");
}
---
<BaseLayout title={data.title} image={data.cover_image?.src}>
  <article class="column has-sidenotes">
    <a class="back-link" href={backHref}>← {backLabel}</a>
    <h1>{data.title}</h1>

    <div class="post-meta">
      <FormattedDate date={data.date} />
      {data.location && <span class="dot">{data.location}</span>}
      {kind === "architecture" && data.architect && <span class="dot">{data.architect}</span>}
      {kind === "architecture" && data.year_built && <span class="dot">Built {data.year_built}</span>}
      {kind === "sports" && data.competition && <span class="dot">{data.competition}</span>}
      {kind === "sports" && data.result && <span class="dot rating">{data.result}</span>}
      {kind === "food" && typeof data.rating === "number" && (
        <span class="dot rating" aria-label={`Rated ${data.rating} out of 5`}>{stars(data.rating)}</span>
      )}
    </div>

    {data.cover_image && (
      <figure>
        <Image
          src={data.cover_image}
          alt={data.cover_alt || data.title}
          widths={[480, 800, 1200]}
          sizes="(max-width: 700px) 92vw, 680px"
        />
      </figure>
    )}

    <div class="prose">
      <slot />
    </div>

    {data.tags && data.tags.length > 0 && (
      <div class="tags" style="margin-top:2rem">
        {data.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}

    <Comments />
  </article>
</BaseLayout>
