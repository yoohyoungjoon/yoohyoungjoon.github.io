---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import GrowthStage from "../components/GrowthStage.astro";
import Comments from "../components/Comments.astro";

interface Props {
  data: {
    title: string;
    date: Date;
    updated?: Date;
    tags?: string[];
    growth_stage: "seedling" | "budding" | "evergreen";
  };
}
const { data } = Astro.props;
---
<BaseLayout title={data.title}>
  <article class="column has-sidenotes">
    <a class="back-link" href="/thoughts">← Thoughts</a>
    <h1>{data.title}</h1>

    <div class="post-meta">
      <GrowthStage stage={data.growth_stage} />
      <span class="dot">Planted <FormattedDate date={data.date} /></span>
      {data.updated && <span class="dot">Tended <FormattedDate date={data.updated} /></span>}
    </div>

    <div class="prose">
      <slot />
    </div>

    {data.tags && data.tags.length > 0 && (
      <div class="tags" style="margin-top:2rem">
        {data.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}

    <Comments />
  </article>
</BaseLayout>
