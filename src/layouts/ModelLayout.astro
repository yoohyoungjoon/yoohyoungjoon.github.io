---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import ModelStatus from "../components/ModelStatus.astro";
import Comments from "../components/Comments.astro";

interface Props {
  data: {
    title: string;
    date: Date;
    tags?: string[];
    status: "planned" | "building" | "live";
    tech?: string[];
    repo?: string;
    demo?: string;
    cover_image?: import("astro").ImageMetadata;
    cover_alt?: string;
  };
}
const { data } = Astro.props;
---
<BaseLayout title={data.title} image={data.cover_image?.src}>
  <article class="column has-sidenotes">
    <a class="back-link" href="/models">← Models</a>
    <h1>{data.title}</h1>

    <div class="post-meta">
      <ModelStatus status={data.status} />
      <span class="dot"><FormattedDate date={data.date} /></span>
      {data.tech && data.tech.length > 0 && <span class="dot">{data.tech.join(" · ")}</span>}
    </div>

    {(data.repo || data.demo) && (
      <div class="project-links">
        {data.repo && <a href={data.repo}>Code repository ↗</a>}
        {data.demo && <a href={data.demo}>Live demo ↗</a>}
      </div>
    )}

    {data.cover_image && (
      <figure>
        <Image
          src={data.cover_image}
          alt={data.cover_alt || data.title}
          widths={[480, 800, 1200]}
          sizes="(max-width: 700px) 92vw, 680px"
        />
      </figure>
    )}

    <div class="prose">
      <slot />
    </div>

    {data.tags && data.tags.length > 0 && (
      <div class="tags" style="margin-top:2rem">
        {data.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}

    <Comments />
  </article>
</BaseLayout>
