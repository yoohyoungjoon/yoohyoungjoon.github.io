---
import { COMMENTS } from "../consts";
// Renders nothing until you flip COMMENTS.ENABLED to true in src/consts.ts
// and paste in your giscus IDs. See that file for the 4-step setup.
const on = COMMENTS.ENABLED;
---
{on && (
  <section class="comments">
    <h2 class="eyebrow">Comments</h2>
    <script
      src="https://giscus.app/client.js"
      data-repo={COMMENTS.repo}
      data-repo-id={COMMENTS.repoId}
      data-category={COMMENTS.category}
      data-category-id={COMMENTS.categoryId}
      data-mapping="pathname"
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="light"
      data-lang="en"
      crossorigin="anonymous"
      async
    />
  </section>
)}
