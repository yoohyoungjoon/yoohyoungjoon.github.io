---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionCard from "../components/SectionCard.astro";

const notDraft = ({ data }: { data: { draft?: boolean } }) => !data.draft;
const [food, architecture, sports, thoughts, models] = await Promise.all([
  getCollection("food", notDraft),
  getCollection("architecture", notDraft),
  getCollection("sports", notDraft),
  getCollection("thoughts", notDraft),
  getCollection("models", notDraft),
]);

const sections = [
  {
    href: "/food",
    title: "Food",
    icon: "food" as const,
    description: "Meals I've cooked, places I've eaten, philosophies of food.",
    count: food.length,
  },
  {
    href: "/architecture",
    title: "Architecture",
    icon: "architecture" as const,
    description: "How do spaces and light affect the way we live.",
    count: architecture.length,
  },
  {
    href: "/sports",
    title: "Sports",
    icon: "sports" as const,
    description: "Reflections on competitions and games.",
    count: sports.length,
  },
  {
    href: "/thoughts",
    title: "Thoughts",
    icon: "thoughts" as const,
    description: "Notes and half-formed ideas.",
    count: thoughts.length,
  },
  {
    href: "/models",
    title: "Models",
    icon: "models" as const,
    description: "Data and machine-learning projects.",
    count: models.length,
  },
];
---
<BaseLayout>
  <div class="shell">
    <section class="intro">
      <p class="eyebrow">Welcome to my notebook</p>
      <h1>Andrew Yoo</h1>
      <p>
        I'm keeping a log of my thoughts on the world. It's only semi regularly updated. Topics range from frivolous to fundamental. Please don't take anything I say too seriously. 
      </p>
    </section>

    <nav class="section-index" aria-label="Sections">
      {sections.map((s) => <SectionCard {...s} />)}
    </nav>
  </div>
</BaseLayout>
